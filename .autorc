{
    plugins: ['released', ['npm', { exact: true } ]],
    baseBranch: 'main',
    noVersionPrefix: true,
    shipit: {
      prerelease: true,
      onlyGraduateWithReleaseLabel: true,
    },
    noDefaultLabels: true,
    versionBranches: false,
    labels: [
      {
        name: 'major',
        description: 'Use for breaking changes that should trigger a major version bump when merged',
        releaseType: 'major',
        color: '#C5000B',
      },
      {
        name: 'minor',
        description: 'Use for new functionality that should trigger a minor version bump when merged',
        releaseType: 'minor',
        color: '#F1A60E',
      },
      {
        name: 'patch',
        description: 'Use for fixes or small improvements that should trigger a patch version bump when merged',
        releaseType: 'patch',
        color: '#870048',
      },
      {
        name: 'skip-release',
        description: 'Prevent Auto from publishing a release for this PR when it is merged',
        releaseType: 'skip',
        color: '#bf5416',
      },
      {
        name: 'release',
        description: 'Graduate the merge from a prerelease publish to a stable latest release',
        releaseType: 'release',
        color: '#007f70',
      },
      {
        name: 'changes',
        changelogTitle: '📦 Misc Changes',
        description: 'Fallback changelog section for merged work that does not match a more specific PR type label',
        releaseType: 'skip',
        default: true,
        color: '#1D76DB',
      },
      {
        name: 'feat',
        changelogTitle: '🚀 Features',
        description: 'Feature work that adds or expands user-facing functionality',
        releaseType: 'none',
        color: '#F1A60E',
      },
      {
        name: 'fix',
        changelogTitle: '🐛 Bug Fixes',
        description: 'Bug fix work that corrects broken or incorrect behavior',
        releaseType: 'none',
        color: '#870048',
      },
      {
        name: 'docs',
        changelogTitle: '📝 Documentation',
        description: 'Documentation-only work such as guides, examples, or API docs',
        releaseType: 'none',
        color: '#CFD3D7',
      },
      {
        name: 'style',
        changelogTitle: '🎨 Styles',
        description: 'Visual or formatting changes that do not alter component behavior',
        releaseType: 'none',
        color: '#5319E7',
      },
      {
        name: 'refactor',
        changelogTitle: '♻️ Refactoring',
        description: 'Code restructuring or cleanup that does not change intended behavior',
        releaseType: 'none',
        color: '#0E8A16',
      },
      {
        name: 'perf',
        changelogTitle: '🏎 Performance',
        description: 'Performance-focused work that improves speed, efficiency, or bundle cost',
        releaseType: 'none',
        color: '#F4B2D8',
      },
      {
        name: 'test',
        changelogTitle: '🧪 Tests',
        description: 'Test-only work such as adding coverage or improving existing test cases',
        releaseType: 'none',
        color: '#FFD3CC',
      },
      {
        name: 'build',
        changelogTitle: '🏗 Build',
        description: 'Build, packaging, dependency, or tooling changes affecting how the project is produced',
        releaseType: 'none',
        color: '#006B75',
      },
      {
        name: 'ci',
        changelogTitle: '🤖 CI',
        description: 'Continuous integration or deployment workflow changes',
        releaseType: 'none',
        color: '#0052CC',
      },
      {
        name: 'chore',
        changelogTitle: '🏠 Chores',
        description: 'General maintenance work that does not fit a more specific change type',
        releaseType: 'none',
        color: '#696969',
      },
      {
        name: 'revert',
        changelogTitle: '⏪ Reverts',
        description: 'Reverts a previous change or backs out an earlier merge',
        releaseType: 'none',
        color: '#B60205',
      },
    ],
}
